#!/usr/bin/env bash
# dev — open a dev workspace in kitty (terminal tab + claude tab)
# Usage: dev [directory]

DIR="${1:-$(pwd)}"
TITLE="$(basename "$DIR")"

if [ -z "$KITTY_LISTEN_ON" ]; then
  echo "Error: not running inside kitty (or remote control is not enabled)"
  exit 1
fi

kitty @ launch --type=tab --tab-title "claude [$TITLE]" --cwd "$DIR" {{ if eq .machine "work" }}cursor-agent{{ else }}claude{{ end }} > /dev/null
